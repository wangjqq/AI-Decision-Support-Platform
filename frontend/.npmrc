# 提升 antd / rc-* / dayjs 等依赖到根 node_modules，避免幽灵依赖问题
# AntD 5 + rc-* 系列需要平铺到顶层才能正确解析样式与上下文
public-hoist-pattern[]=*antd*
public-hoist-pattern[]=*rc-*
public-hoist-pattern[]=*@ant-design/*
public-hoist-pattern[]=*@code-inspector*
public-hoist-pattern[]=dayjs

# 严格模式：禁止访问未在 package.json 中声明的依赖
strict-peer-dependencies=false
auto-install-peers=true

# 安装提速
prefer-frozen-lockfile=true
